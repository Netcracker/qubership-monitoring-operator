# File will be loaded as environment variables
# It must contain strings like:
# name=value

GITLEAKS_LOG_LEVEL=warn
MARKDOWN_CONFIG_FILE=.markdownlint.yaml

# Disable DevOps linters
VALIDATE_CHECKOV=false
VALIDATE_JSCPD=false
VALIDATE_KUBERNETES_KUBECONFORM=false
VALIDATE_MARKDOWN_PRETTIER=false
VALIDATE_YAML_PRETTIER=false

# Disable rest of python linters, should use only flake8
VALIDATE_PYTHON_BLACK=false
VALIDATE_PYTHON_MYPY=false
VALIDATE_PYTHON_PYLINT=false
VALIDATE_PYTHON_RUFF=false
VALIDATE_PYTHON_RUFF_FORMAT=false

# Disable Golang linter that doesn't support modules
VALIDATE_GO=false

# Disable JS/TS linters
VALIDATE_BIOME_FORMAT=false
VALIDATE_BIOME_LINT=false
VALIDATE_CSS=false
VALIDATE_CSS_PRETTIER=false
VALIDATE_JAVASCRIPT_ES=false
VALIDATE_JAVASCRIPT_PRETTIER=false
VALIDATE_JSON_PRETTIER=false
VALIDATE_TYPESCRIPT_ES=false
VALIDATE_VUE=false

# Disable rest of linters
VALIDATE_SPELL_CODESPELL=false
