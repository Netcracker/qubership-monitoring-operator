# Broad selector used for cardinality-oriented views, especially top metrics by series.
# This may be wider than SELECTOR, because cardinality analysis often targets all user metrics,
# not only VictoriaMetrics self-metrics.
CARDINALITY_SELECTOR=cluster="prod"

# Window used for churn totals such as new_series_total and Top Services By New Series.
CHURN_LOOKBACK=24h

# Label name used by the optional ingestion-by-cluster table.
CLUSTER_INGESTION_LABEL=cluster

# If true, do not query VictoriaMetrics; output only generated query plans.
DRY_RUN=false

# Optional table which groups ingestion rate by a cluster label.
# Keep false unless you explicitly want this extra breakdown.
ENABLE_CLUSTER_INGESTION_TABLE=false

# When true, scan all metric names for label-distribution analysis.
# This is much heavier than the default top-metrics-only mode.
FULL_LABEL_SCAN=false

# Optional hard cap for FULL_LABEL_SCAN metric names.
# Use 0 to disable the cap.
MAX_FULL_SCAN_METRICS=0

# Maximum number of /api/v1/series rows fetched per metric when FULL_LABEL_SCAN=true.
# Use 0 for no explicit limit.
GLOBAL_SERIES_FETCH_LIMIT=0

# Optional HTML output path.
HTML_OUTPUT=vm-storage-report.html

# Warn when indexdb/file size becomes larger than storage/big + storage/small.
INDEX_RATIO_WARNING_THRESHOLD=1.0

# Set true for self-signed / internal TLS endpoints.
INSECURE_SKIP_VERIFY=false

# Only show labels occupying at least this share of active series in Label Distribution.
LABEL_SERIES_SHARE_THRESHOLD=0.05

# Historical compatibility setting for label localization heuristics.
# In the current report it is mostly a soft tuning knob for label review logic.
LABEL_LOW_METRIC_COVERAGE_THRESHOLD=0.3

# Keep globally present non-infra labels in Label Distribution when they have
# at least this many unique values.
LABEL_GLOBAL_UNIQUE_VALUES_THRESHOLD=100

# Cleanup heuristic: treat metrics whose last request is older than this many days as stale.
METRIC_LAST_REQUEST_OLD_DAYS=30

# How many top high-cardinality metrics are inspected with /api/v1/series to find Top Label.
# Effective value is never lower than TOP_LIMIT.
METRIC_LABEL_ANALYSIS_LIMIT=10

# Cleanup heuristic: treat metrics with queryRequestsCount <= this value as low-usage.
METRIC_REQUEST_LOW_THRESHOLD=0

# How many rows to request from /api/v1/status/metric_names_stats for joins with
# High Cardinality Metric Usage. Increase if usage columns are empty for expected metrics.
METRIC_USAGE_LIMIT=5000

# Namespace used for CPU throttling and CPU pressure checks.
# These queries always use:
# - container="vmsingle",namespace="<value>"
# - container="vmagent",namespace="<value>"
MONITORING_NAMESPACE=monitoring

# Required JSON output path.
OUTPUT=vm-storage-report.json

# Regex for vm_request_duration_seconds_* paths counted as query / metric API traffic.
# Usually the default is fine.
QUERY_REQUESTS_PATH_REGEX=.*/api/v1/(query|query_range|series|labels|label/.+/values|status/tsdb|status/metric_names_stats)$

# Window for rate() queries such as ingestion rate, request rate and slow-query rate.
RATE_WINDOW=5m

# Optional selector for scrape_series_added when building "Top Services By New Series".
# Leave empty to include all scrape targets known to vmagent.
SCRAPE_SELECTOR=

# Selector for VictoriaMetrics self-monitoring metrics such as vm_rows,
# vm_data_size_bytes, vm_cache_entries and vm_free_disk_space_bytes.
# Use it to limit the report to the relevant VictoriaMetrics target(s).
# Example: cluster="prod",job=~"vmsingle|vmstorage"
SELECTOR=cluster="prod",job=~"vmsingle"

# Maximum number of /api/v1/series rows fetched for one metric during label-driver analysis.
# Large values improve accuracy but make the script heavier.
SERIES_SAMPLE_LIMIT=20000

# Maximum number of parallel workers used for /api/v1/series and missing label-values fetches.
# Lower it for very large VictoriaMetrics installations if the API becomes too busy.
SERIES_FETCH_WORKERS=8

# Labels used to group both service tables:
# - Top Services By Active Series
# - Top Services By New Series
# Default is namespace,job because it usually maps well to microservices.
SERVICE_GROUP_BY_LABELS=namespace,job

# Warn when slow inserts exceed this share of inserted rows.
SLOW_INSERTS_WARNING_THRESHOLD=0.02

# Window used to estimate current disk growth trend for storage_full_eta_days.
STORAGE_ETA_LOOKBACK=24h

# Top N limit for visible ranking tables.
TOP_LIMIT=10

# Top N row limit for /api/v1/status/top_queries tables.
TOP_QUERIES_LIMIT=10

# Lookback window passed as maxLifetime to /api/v1/status/top_queries.
TOP_QUERIES_LOOKBACK=24h

# Shift report time into the past. Example: 2h means "build report for now-2h".
TIME_OFFSET=0s

# Base VictoriaMetrics URL, for example vmsingle or vmauth /select/0/prometheus.
VICTORIAMETRICS_URL=http://victoria-metrics:8428

# Optional custom PromQL for vmalert traffic.
# Leave empty for the built-in behavior:
# - use vmalert_datasource_queries_total when available
# - otherwise fall back to vmalert_execution_total as a proxy
VMALERT_REQUESTS_QUERY=

# Optional Basic Auth credentials for VictoriaMetrics / vmauth.
VM_PASS=

# Optional Basic Auth credentials for VictoriaMetrics / vmauth.
VM_USER=
