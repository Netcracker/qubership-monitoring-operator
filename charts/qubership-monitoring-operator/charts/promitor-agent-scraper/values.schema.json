{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "affinity": {
            "type": "object",
            "description": "Pod affinity rules for promitor-agent-scraper.",
            "default": {}
        },
        "annotations": {
            "type": "object",
            "description": "Annotations to add to promitor-agent-scraper resources.",
            "default": {}
        },
        "azureAuthentication": {
            "type": "object",
            "description": "Azure authentication settings for promitor-agent-scraper.",
            "properties": {
                "identity": {
                    "type": "object",
                    "description": "Azure identity details used for authentication.",
                    "properties": {
                        "binding": {
                            "type": "string",
                            "description": "Add Pod Identity name when using UserAssignedManagedIdentity or SystemAssignedManagedIdentity as mode.",
                            "default": ""
                        },
                        "id": {
                            "type": "string",
                            "description": "Id of the Azure AD entity to authenticate with.",
                            "default": ""
                        },
                        "key": {
                            "type": "string",
                            "description": "Secret of the Azure AD entity to authenticate with. Sets the environment variable PROMITOR_AUTH_APPKEY through the secrets.appKeySecret field in the Secret.",
                            "default": ""
                        }
                    }
                },
                "mode": {
                    "type": "string",
                    "description": "Authentication type to use to authenticate. Options are ServicePrincipal, UserAssignedManagedIdentity or SystemAssignedManagedIdentity.",
                    "default": "ServicePrincipal"
                }
            }
        },
        "azureMetadata": {
            "type": "object",
            "description": "Azure metadata configuration used by Promitor.",
            "properties": {
                "cloud": {
                    "type": "string",
                    "description": "The name of the Azure cloud to use. Options are Global (default), China, UsGov & Germany",
                    "default": "Global"
                },
                "resourceGroupName": {
                    "type": "string",
                    "description": "The name of the default resource group to query.",
                    "default": ""
                },
                "subscriptionId": {
                    "type": "string",
                    "description": "The id of the default subscription to query.",
                    "default": ""
                },
                "tenantId": {
                    "type": "string",
                    "description": "The id of the Azure tenant that will be queried.",
                    "default": ""
                }
            }
        },
        "image": {
            "type": "string",
            "description": "Docker image for promitor-agent-scraper deployment.\nDefault: ghcr.io/tomkerkhove/promitor-agent-scraper:2.13.0"
        },
        "imagePullPolicy": {
            "type": "string",
            "description": "Image pull policy to use for promitor-agent-scraper deployment.",
            "default": "IfNotPresent"
        },
        "install": {
            "type": "boolean",
            "description": "Allow to enable deploy promitor-agent-scraper.",
            "default": false
        },
        "labels": {
            "type": "object",
            "description": "Labels to add to promitor-agent-scraper pods."
        },
        "metricDefaults": {
            "type": "object",
            "description": "Default metric collection configuration for Promitor.",
            "properties": {
                "aggregation": {
                    "type": "object",
                    "description": "Default aggregation settings for metrics.",
                    "properties": {
                        "interval": {
                            "type": "string",
                            "description": "The default interval over which measurements of a metric should be aggregated.",
                            "default": "00:05:00"
                        }
                    }
                },
                "scraping": {
                    "type": "object",
                    "description": "Default scraping schedule settings for metrics.",
                    "properties": {
                        "schedule": {
                            "type": "string",
                            "description": "A cron expression that controls the frequency of scraping configured metrics from Azure Monitor.",
                            "default": "*/5 * * * *"
                        }
                    }
                }
            }
        },
        "metricSinks": {
            "type": "object",
            "description": "Metric sink settings for promitor-agent-scraper.",
            "properties": {
                "prometheusScrapingEndpoint": {
                    "type": "object",
                    "description": "Settings for the Prometheus scraping endpoint.",
                    "properties": {
                        "baseUriPath": {
                            "type": "string",
                            "description": "Controls the path where the scraping endpoint for Prometheus is exposed.",
                            "default": "/metrics"
                        },
                        "enableMetricTimestamps": {
                            "type": "boolean",
                            "description": "Defines whether a timestamp should be included when the value was scraped on Azure Monitor.",
                            "default": true
                        },
                        "labelTransformation": {
                            "type": "string",
                            "description": "Controls how label values are reported to Prometheus by using transformation. Options are None and Lowercase.",
                            "default": "None"
                        },
                        "metricUnavailableValue": {
                            "type": "string",
                            "description": "Defines the value that will be reported if a metric is unavailable.",
                            "default": "NaN"
                        }
                    }
                }
            }
        },
        "metrics": {
            "type": "array",
            "description": "List of metrics to scrape.",
            "default": [],
            "examples": [
                [
                    {
                        "name": "demo_queue_size",
                        "description": "Amount of active messages of the 'myqueue' queue (determined with ServiceBusQueue provider)",
                        "resourceType": "ServiceBusQueue",
                        "azureMetricConfiguration": {
                            "metricName": "ActiveMessages",
                            "aggregation": {
                                "type": "Total",
                                "interval": "00:15:00"
                            }
                        },
                        "resources": [
                            {
                                "namespace": "promitor-messaging",
                                "queueName": "orders"
                            }
                        ]
                    }
                ]
            ]
        },
        "name": {
            "type": "string",
            "description": "Name of promitor-agent-scraper used in deployment and other object names.",
            "default": "promitor-agent-scraper"
        },
        "nodeSelector": {
            "type": "object",
            "description": "Node selector settings for promitor-agent-scraper pods.",
            "default": {}
        },
        "priorityClassName": {
            "type": "string",
            "description": "PriorityClassName assigned to the Pods to prevent them from evicting."
        },
        "replicas": {
            "type": "integer",
            "description": "Replicas spec configuration for promitor-agent-scraper.",
            "default": 1
        },
        "resourceDiscovery": {
            "type": "object",
            "description": "Promitor resource discovery agent connection settings.",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "description": "Indication whether resource discovery is enabled through the Promitor Resource Discovery agent.",
                    "default": false
                },
                "host": {
                    "type": "string",
                    "description": "DNS name or IP address of the Promitor Resource Discovery agent.",
                    "default": ""
                },
                "port": {
                    "type": "integer",
                    "description": "Port (UDP) address of the Promitor Resource Discovery agent.",
                    "default": 80
                }
            }
        },
        "resources": {
            "type": "object",
            "description": "Compute resource requests and limits for promitor-agent-scraper.",
            "default": {},
            "properties": {
                "limits": {
                    "type": "object",
                    "description": "Maximum resources allowed for promitor-agent-scraper containers.",
                    "default": {},
                    "properties": {
                        "cpu": {
                            "type": "string",
                            "description": "The maximum amount of CPU allowed for promitor-agent-scraper containers."
                        },
                        "memory": {
                            "type": "string",
                            "description": "The maximum amount of memory allowed for promitor-agent-scraper containers."
                        }
                    }
                },
                "requests": {
                    "type": "object",
                    "description": "Minimum resources required for promitor-agent-scraper containers.",
                    "default": {},
                    "properties": {
                        "cpu": {
                            "type": "string",
                            "description": "The minimum amount of CPU required for promitor-agent-scraper containers."
                        },
                        "memory": {
                            "type": "string",
                            "description": "The minimum amount of memory required for promitor-agent-scraper containers."
                        }
                    }
                }
            }
        },
        "secrets": {
            "type": "object",
            "description": "Secrets configuration for Azure authentication.",
            "properties": {
                "appKeySecret": {
                    "type": "string",
                    "description": "Name of the field for Azure AD identity secret in the Secret resource.",
                    "default": "azure-app-key"
                },
                "createSecret": {
                    "type": "boolean",
                    "description": "Whether to create the Azure AD identity secret automatically.",
                    "default": true
                },
                "secretName": {
                    "type": "string",
                    "description": "Name of the secret for Azure AD identity secret.",
                    "default": "promitor-agent-scraper"
                }
            }
        },
        "securityContext": {
            "type": "object",
            "description": "Pod-level security attributes for promitor-agent-scraper.",
            "default": {},
            "properties": {
                "fsGroup": {
                    "type": "integer",
                    "description": "A special supplemental group that applies to all containers in a pod."
                },
                "runAsUser": {
                    "type": "integer",
                    "description": "The UID to run the entrypoint of the container process."
                }
            }
        },
        "service": {
            "type": "object",
            "description": "Service configuration for promitor-agent-scraper.",
            "properties": {
                "azureLoadBalancer": {
                    "type": "object",
                    "description": "Azure load balancer settings for the service.",
                    "properties": {
                        "dnsPrefix": {
                            "type": "string",
                            "description": "Prefix for DNS name to expose the service on using <name>.<location>.cloudapp.azure.com format. Azure Kubernetes Service only."
                        },
                        "exposeInternally": {
                            "type": "boolean",
                            "description": "Restrict access by exposing the service through an internal Azure load balancer.",
                            "default": false
                        }
                    }
                },
                "labels": {
                    "type": "object",
                    "description": "Labels set on the service.",
                    "default": {}
                },
                "port": {
                    "type": "integer",
                    "description": "Port of promitor-agent-scraper used by the service.",
                    "default": 8888
                },
                "targetPort": {
                    "type": "integer",
                    "description": "Target port of promitor-agent-scraper used in the service and container.",
                    "default": 5000
                },
                "type": {
                    "type": "string",
                    "description": "Type of promitor-agent-scraper service.",
                    "default": "ClusterIP"
                }
            }
        },
        "serviceAccount": {
            "type": "object",
            "description": "ServiceAccount configuration for promitor-agent-scraper.",
            "properties": {
                "annotations": {
                    "type": "object",
                    "description": "Annotations to add to the created ServiceAccount.",
                    "default": {}
                },
                "install": {
                    "type": "boolean",
                    "description": "Specifies whether a ServiceAccount should be created.",
                    "default": true
                },
                "labels": {
                    "type": "object",
                    "description": "Labels to add to the created ServiceAccount.",
                    "default": {}
                },
                "name": {
                    "type": "string",
                    "description": "The name of the ServiceAccount to use.",
                    "default": "promitor-agent-scraper"
                }
            }
        },
        "serviceMonitor": {
            "type": "object",
            "description": "ServiceMonitor configuration for Prometheus scraping.",
            "properties": {
                "install": {
                    "type": "boolean",
                    "description": "When set true then use a ServiceMonitor to configure scraping.",
                    "default": true
                },
                "interval": {
                    "type": "string",
                    "description": "How frequently Prometheus should scrape.",
                    "default": "5m"
                },
                "metricRelabelings": {
                    "type": "array",
                    "description": "Set metricRelabelings for the ServiceMonitor, use to apply to samples for ingestion.",
                    "default": []
                },
                "labels": {
                    "type": "object",
                    "description": "Labels for the ServiceMonitor.",
                    "default": {
                        "app.kubernetes.io/component": "monitoring"
                        }
                },
                "relabelings": {
                    "type": "array",
                    "description": "Set relabelings for the ServiceMonitor, use to apply to samples before scraping.",
                    "default": []
                },
                "telemetryPath": {
                    "type": "string",
                    "description": "Path used by the ServiceMonitor to scrape telemetry.",
                    "default": "/metrics"
                }
            }
        },
        "telemetry": {
            "type": "object",
            "description": "Telemetry configuration for promitor-agent-scraper.",
            "properties": {
                "applicationInsights": {
                    "type": "object",
                    "description": "Application Insights telemetry settings.",
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "description": "Whether the Application Insights sink is enabled.",
                            "default": false
                        },
                        "key": {
                            "type": "string",
                            "description": "Instrumentation key for Application Insights.",
                            "default": ""
                        },
                        "logLevel": {
                            "type": "string",
                            "description": "Log level for Application Insights.",
                            "default": ""
                        }
                    }
                },
                "containerLogs": {
                    "type": "object",
                    "description": "Container log sink settings.",
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "description": "Whether container logs are enabled.",
                            "default": true
                        },
                        "logLevel": {
                            "type": "string",
                            "description": "Log level for container logs.",
                            "default": ""
                        }
                    }
                },
                "defaultLogLevel": {
                    "type": "string",
                    "description": "Default minimum log level if a sink does not provide one.",
                    "default": "Error"
                }
            }
        },
        "tolerations": {
            "type": "array",
            "description": "Pod tolerations for promitor-agent-scraper.",
            "default": []
        }
    }
}
